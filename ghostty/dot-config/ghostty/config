# macOS shortcuts forwarded into tmux
#
# These bindings intentionally bypass Ghostty actions and send literal key
# sequences into the terminal. `\x02` is Ctrl-b, tmux's prefix, so each line is
# equivalent to pressing: tmux prefix, then the tmux binding key.
#
# Keep host-level shortcuts that control tmux here, and keep the actual tmux
# behavior in tmux/dot-tmux.conf.

# Panes.
# Cmd-d       -> prefix %  -> split right
# Cmd-Shift-d -> prefix "  -> split down
# Cmd-Shift-Enter -> prefix z -> zoom/unzoom pane
keybind = super+d=text:\x02%
keybind = super+shift+d=text:\x02\"
keybind = super+shift+enter=text:\x02z

# Windows/sessions.
# Cmd-t -> prefix c -> new window
# Cmd-w -> prefix x -> kill pane/window prompt
keybind = super+t=text:\x02c
keybind = super+w=text:\x02x

# Window switching.
# Cmd-<number> -> prefix <number>. tmux is configured with base-index 1.
# Use digit_N to override Ghostty's default Cmd-N tab switching on macOS.
keybind = super+digit_1=text:\x021
keybind = super+digit_2=text:\x022
keybind = super+digit_3=text:\x023
keybind = super+digit_4=text:\x024
keybind = super+digit_5=text:\x025
keybind = super+digit_6=text:\x026
keybind = super+digit_7=text:\x027
keybind = super+digit_8=text:\x028
keybind = super+digit_9=text:\x029
keybind = super+0=text:\x020
